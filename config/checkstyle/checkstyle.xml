<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="severity" value="error"/>

    <module name="SuppressionFilter">
        <property name="file" value="${config_loc}/suppressions.xml"/>
    </module>

    <module name="TreeWalker">
        <!--
            Ban primitive double and float as field, variable, parameter, and return types.
            Monetary amounts must use BigDecimal. GPS coordinates are suppressed via suppressions.xml.
        -->
        <module name="IllegalType">
            <property name="id" value="NoPrimitiveMoneyTypes"/>
            <property name="illegalClassNames" value="double, float"/>
            <property name="tokens" value="VARIABLE_DEF, METHOD_DEF, PARAMETER_DEF"/>
            <message key="illegal.type"
                     value="Do not use ''{0}'' for monetary or quantitative fields. Use BigDecimal. GPS coordinates must be suppressed explicitly."/>
        </module>
    </module>
</module>
