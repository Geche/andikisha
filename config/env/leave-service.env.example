# ── Leave Service ──
SERVER_PORT=8087
GRPC_SERVER_PORT=9087

# ── Database ──
DB_HOST=localhost
DB_PORT=5439
DB_NAME=andikisha_leave
DB_USERNAME=andikisha
DB_PASSWORD=changeme

# ── Messaging ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=andikisha
RABBITMQ_PASSWORD=changeme

# ── Security ──
JWT_SECRET=replace-with-real-256-bit-secret-before-running

# ── Observability ──
