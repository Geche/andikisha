# ── Auth Service ──
SERVER_PORT=8081
GRPC_SERVER_PORT=9081

# ── Database ──
DB_HOST=localhost
DB_PORT=5433
DB_NAME=andikisha_auth
DB_USERNAME=andikisha
DB_PASSWORD=changeme

# ── Messaging ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=andikisha
RABBITMQ_PASSWORD=changeme

# ── Security ──
JWT_SECRET=replace-with-real-256-bit-secret-before-running

# ── Observability ──
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# ── Spring ──
SPRING_PROFILES_ACTIVE=dev

# ── Token cache ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── JWT lifetimes (overridable) ──
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
