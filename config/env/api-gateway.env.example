# ── API Gateway ──
SERVER_PORT=8080

# ── Messaging ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=andikisha
RABBITMQ_PASSWORD=changeme

# ── Security ──
JWT_SECRET=replace-with-real-256-bit-secret-before-running

# ── Observability ──
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# ── Spring ──
SPRING_PROFILES_ACTIVE=dev

# ── gRPC Clients (downstream services) ──
AUTH_GRPC_HOST=localhost
AUTH_GRPC_PORT=9081
EMPLOYEE_GRPC_HOST=localhost
EMPLOYEE_GRPC_PORT=9082
TENANT_GRPC_HOST=localhost
TENANT_GRPC_PORT=9083
PAYROLL_GRPC_HOST=localhost
PAYROLL_GRPC_PORT=9084
COMPLIANCE_GRPC_HOST=localhost
COMPLIANCE_GRPC_PORT=9085
TIME_GRPC_HOST=localhost
TIME_GRPC_PORT=9086
LEAVE_GRPC_HOST=localhost
LEAVE_GRPC_PORT=9087
DOCUMENT_GRPC_HOST=localhost
DOCUMENT_GRPC_PORT=9088
NOTIFICATION_GRPC_HOST=localhost
NOTIFICATION_GRPC_PORT=9089
INTEGRATION_GRPC_HOST=localhost
INTEGRATION_GRPC_PORT=9090
ANALYTICS_GRPC_HOST=localhost
ANALYTICS_GRPC_PORT=9091
AUDIT_GRPC_HOST=localhost
AUDIT_GRPC_PORT=9092

# ── Rate limiting ──
REDIS_HOST=localhost
REDIS_PORT=6379
