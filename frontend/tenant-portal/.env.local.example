# ─── AndikishaHR Tenant Portal ────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# URL of the API Gateway service (default: local dev gateway)
API_GATEWAY_URL=http://localhost:8080

# UUID of the tenant this portal instance serves.
# Set this per-deployment. Each tenant gets their own portal deployment.
TENANT_ID=your-tenant-uuid-here

# Base64-encoded JWT secret — must match the secret in auth-service (JwtTokenProvider).
# Generate: openssl rand -base64 64
JWT_SECRET=your-base64-encoded-secret-here

# Node environment (development | production)
NODE_ENV=development
