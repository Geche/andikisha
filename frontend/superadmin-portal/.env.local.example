# AndikishaHR Super Admin Portal — Environment Variables
# Copy this file to .env.local and fill in the values.

# API Gateway base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080

# JWT secret — must match the value used by the api-gateway and auth-service.
# Used by the middleware to verify SUPER_ADMIN tokens server-side.
# Never commit the real value. In production, inject via Kubernetes secret.
JWT_SECRET=your-base64-encoded-jwt-secret-here

# Next.js internal
NEXTAUTH_URL=http://localhost:3003
