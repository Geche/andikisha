# .env — AndikishaHR VPS / Dokploy deployment
# Copy this file to .env and fill in all values before running docker compose up.
# NEVER commit .env to git.

# ── Registry ──────────────────────────────────────────────────────────────────
# Lowercase GitHub username or org that owns the ghcr.io packages.
GHCR_OWNER=your-github-username

# ── Release tag ───────────────────────────────────────────────────────────────
# Leave blank (or set to 'latest') for normal deploys.
# Set to a previous git SHA (e.g. abc1234) to roll back.
RELEASE_TAG=latest

# ── Domains ───────────────────────────────────────────────────────────────────
API_DOMAIN=api.andikisha.co.ke
TENANT_DOMAIN=app.andikisha.co.ke
PLATFORM_DOMAIN=platform.andikisha.co.ke
LANDING_DOMAIN=andikisha.co.ke

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=andikisha
POSTGRES_PASS=change-me-strong-password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=andikisha
RABBITMQ_PASS=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASS=change-me-strong-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 64 characters for HS512. Generate with:
#   openssl rand -hex 64
JWT_SECRET=replace-with-64-plus-char-random-hex-string

# ── Integration Hub ───────────────────────────────────────────────────────────
# Must be exactly 32 characters (AES-256). If it contains special characters,
# wrap the value in single quotes: CREDENTIAL_ENCRYPTION_KEY='key'
# Generate with: openssl rand -base64 24 | tr -d '=' | head -c 32
CREDENTIAL_ENCRYPTION_KEY=replace-with-exactly-32-char-key

# ── Email / SMTP ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-app-password
MAIL_FROM=noreply@andikisha.co.ke

# ── SMS (optional) ────────────────────────────────────────────────────────────
SMS_ENABLED=false
SMS_API_KEY=

# ── M-Pesa (optional) ─────────────────────────────────────────────────────────
MPESA_ENABLED=false
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
