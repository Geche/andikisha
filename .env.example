# .env.example — copy to .env on your VPS and fill in real values.
# Never commit .env to source control.

# ── GitHub Container Registry ─────────────────────────────────────────────────
# GitHub username or org that owns the repo (lowercase).
GHCR_OWNER=your-github-username

# ── Domains (managed by Dokploy + Traefik) ───────────────────────────────────
TENANT_DOMAIN=app.yourdomain.com
PLATFORM_DOMAIN=platform.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=andikisha
POSTGRES_PASS=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASS=change-me-redis-password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=andikisha
RABBITMQ_PASS=change-me-rabbitmq-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-generate-a-real-secret

# ── Encryption key (integration-hub-service) ─────────────────────────────────
# Must be exactly 32 characters for AES-256.
CREDENTIAL_ENCRYPTION_KEY=change-me-exactly-32-chars-here!

# ── Email (notification-service) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com

# ── SMS — Africa's Talking or similar (notification-service) ─────────────────
SMS_ENABLED=false
SMS_API_KEY=

# ── M-Pesa (integration-hub-service) ─────────────────────────────────────────
MPESA_ENABLED=false
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
