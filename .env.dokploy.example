# .env.dokploy.example — environment variables for docker-stack.yml (Dokploy Stack/Swarm mode)
#
# Copy the variables below into the Dokploy Compose service's "Environment" tab
# (or a .env alongside docker-stack.yml). Fill in real domains, passwords, and
# generated secrets. NEVER commit the filled-in file — only this example.
#
# Every value here is referenced by docker-stack.yml via ${VAR} interpolation.
# Variables NOT listed (DB_HOST, RABBITMQ_HOST, service URLs, etc.) are hardcoded
# in the stack and need no override.

# ─── Images ────────────────────────────────────────────────────────────────
# GitHub owner/org in the image path: ghcr.io/${GHCR_OWNER}/andikisha/<service>.
# Private repo → add a GHCR registry credential in Dokploy so pulls succeed.
GHCR_OWNER=your-github-org
# Image tag to deploy. Pin to a version/SHA for reproducible deploys.
RELEASE_TAG=latest

# ─── Datastores ──────────────────────────────────────────────────────────────
# POSTGRES_USER has no working default — if unset the DB is created with an
# empty user and every service fails to connect.
POSTGRES_USER=andikisha
POSTGRES_PASS=CHANGE_ME          # openssl rand -base64 24
REDIS_PASS=CHANGE_ME             # openssl rand -base64 24
RABBITMQ_USER=andikisha
RABBITMQ_PASS=CHANGE_ME          # openssl rand -base64 24

# ─── Secrets ─────────────────────────────────────────────────────────────────
# The two secrets use DIFFERENT Base64 alphabets and are validated at startup.
# Do NOT reuse one value for both, and do NOT hand-write them.
#
# JWT_SECRET — signs/verifies JWTs in auth-service AND api-gateway.
#   * Must be URL-safe Base64 (-_ , no +//). Four api-gateway filters use
#     getUrlDecoder() and throw on a + or / character.
#   * Must decode to >= 32 bytes; auth-service rejects shorter at boot.
#   * 64 bytes -> HS512 (recommended).
#   Generate:  openssl rand -base64 64 | tr '+/' '-_' | tr -d '=\n'
JWT_SECRET=CHANGE_ME
#
# CREDENTIAL_ENCRYPTION_KEY — AES-256-GCM key for stored integration creds.
#   * Standard Base64 (keep +///=).
#   * Must decode to EXACTLY 32 bytes; integration-hub crashes at boot otherwise.
#   Generate:  openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME

# ─── Domains ─────────────────────────────────────────────────────────────────
# DNS A records for all four must point at the VPS BEFORE first deploy, or
# Let's Encrypt cert issuance (traefik certresolver=letsencrypt) will fail.
API_DOMAIN=api.andikisha.co.ke
TENANT_DOMAIN=app.andikisha.co.ke
PLATFORM_DOMAIN=platform.andikisha.co.ke
LANDING_DOMAIN=andikisha.co.ke

# ─── Mail (notification-service) ─────────────────────────────────────────────
# Required only if outbound email is needed. For Gmail, MAIL_PASSWORD must be an
# App Password, not the account password.
MAIL_USERNAME=
MAIL_PASSWORD=
# Optional overrides (defaults shown):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_FROM=noreply@andikisha.co.ke

# ─── Optional integrations (off by default) ──────────────────────────────────
# Enable + fill only when real credentials exist.
MPESA_ENABLED=false
# MPESA_ENV=sandbox            # sandbox | production
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
SMS_ENABLED=false
# SMS_API_KEY=

# ─── Infra prerequisites (NOT env vars, listed for reference) ────────────────
# * dokploy-network (external overlay) must exist — Dokploy creates it when
#   Swarm is enabled.
# * BANK_TRANSFER_ENABLED and MPESA_CALLBACK_IP_VALIDATION_DISABLED are
#   hardcoded in docker-stack.yml, not env-driven.
